# Streamlit Cloud secrets template.
#
# This file is just documentation — DO NOT put real secrets here and
# commit it. On Streamlit Cloud, go to your app -> Settings -> Secrets
# and paste the contents below (with real values) directly into that
# UI panel. Streamlit Cloud stores it securely and exposes it to the
# app via st.secrets AND as environment variables (this app reads
# os.environ, and bootstrap.py below copies st.secrets into the
# environment automatically so no other code needs to change).

CEO_EMAIL = "you@example.com"
CEO_PASSWORD = "choose-a-strong-password"

SHARD_1_SUPABASE_URL = "https://xxxxxxxx.supabase.co"
SHARD_1_SUPABASE_ANON_KEY = "your-anon-public-key"
SHARD_1_SUPABASE_SERVICE_ROLE_KEY = "your-service-role-key"

RESEND_API_KEY = "re_your_api_key"
EMAIL_FROM = "Parent2Parent <noreply@yourdomain.com>"
